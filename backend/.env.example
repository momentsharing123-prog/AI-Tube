PORT={backend_port}
# Maximum number of items downloaded per single playlist API call (playlist-mp3 / playlist-mp4).
# The caller can override this per-request via the "limit" body parameter.
# Default: 100
# PLAYLIST_DOWNLOAD_LIMIT=100
# Deployment security model for admin capabilities: application | container | host
# Default: container
# MYTUBE_ADMIN_TRUST_LEVEL=container
# Optional: yt-dlp JS runtime for YouTube challenge solving.
# Default: deno
# Use node on Alpine Linux (musl) if deno is unstable.
# YT_DLP_JS_RUNTIME=node
